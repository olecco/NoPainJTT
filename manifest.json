{
  "manifest_version": 3,
  "name": "No Pain JTT",
  "version": "1.1.0",
  "description": "Login helper for JTT (Chrome MV3).",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "cookies"
  ],
  "host_permissions": [
    "https://jtt.in.devexperts.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "No Pain JTT",
    "default_popup": "launcher.html"
  }
}
